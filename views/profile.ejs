<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <style>
    .profile-card {
      max-width: 600px;
      margin: 40px auto;
      padding: 40px;
      background: #FFFFFF;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-liquid);
      border: 1px solid var(--border-subtle);
      position: relative;
    }
    
    .avatar-upload {
      position: relative;
      max-width: 120px;
      margin: 0 auto 30px auto;
      cursor: pointer;
    }

    .avatar-preview {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: var(--bg-subtle);
      border: 2px dashed var(--border-subtle);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
      transition: all 0.3s ease;
    }

    .avatar-preview img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: none;
    }

    .avatar-preview .upload-icon {
      color: var(--text-muted);
      position: absolute;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 5px;
    }

    .avatar-upload:hover .avatar-preview {
      border-color: var(--accent-gold);
    }
    
    .avatar-upload:hover .upload-icon {
      color: var(--accent-gold);
    }
    
    .avatar-preview.has-image .upload-icon {
      display: none;
    }
    
    .avatar-preview.has-image:hover::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(27, 38, 59, 0.5);
      border-radius: 50%;
    }
    
    .avatar-preview.has-image:hover .upload-icon {
      display: flex;
      color: #fff;
      z-index: 2;
    }

    .readonly-input {
      background: #f3f4f6 !important;
      color: #9ca3af !important;
      cursor: not-allowed;
    }
  </style>
</head>
<body style="display: none;">

  <%- include('partials/header') %>

  <main class="container" style="padding-top: 40px; padding-bottom: 80px;">
    <div class="profile-card">
      <h2 class="brand-font" style="text-align: center; margin-bottom: 30px; font-size: 2rem;">My Profile</h2>
      
      <form id="profileForm" enctype="multipart/form-data">
        <div class="avatar-upload" id="avatarUploadTrigger">
          <div class="avatar-preview" id="avatarPreview">
            <div class="upload-icon">
              <i data-lucide="camera" style="width: 24px; height: 24px;"></i>
              <span style="font-size: 0.7rem; font-family: 'Montserrat', sans-serif;">Change</span>
            </div>
            <img id="avatarImage" src="/images/default-avatar.png" alt="Avatar">
          </div>
          <input type="file" id="profilePicture" name="profilePicture" accept="image/*" style="display: none;">
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label class="form-label" for="firstName">First Name *</label>
            <input type="text" id="firstName" name="firstName" class="form-control" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="lastName">Last Name *</label>
            <input type="text" id="lastName" name="lastName" class="form-control" required>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input type="email" id="email" name="email" class="form-control readonly-input" readonly>
          <small style="color: var(--text-muted); display: block; margin-top: 4px;">Email cannot be changed.</small>
        </div>

        <div class="form-group">
          <label class="form-label" for="password">New Password</label>
          <input type="password" id="password" name="password" class="form-control" placeholder="Leave blank to keep current password">
        </div>

        <button type="submit" class="btn-submit" id="saveProfileBtn" style="margin-top: 10px;">Save Changes</button>
      </form>
    </div>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/scripts') %>
  <script src="/js/profile.js"></script>
  <script>
    if (window.lucide) {
      lucide.createIcons();
    }
  </script>
</body>
</html>
