    <a href="/admin/brands" class="admin-subnav-link <%= locals.activeTab === 'brands' ? 'active' : '' %>">Brands</a>
    <a href="/admin/categories"
      class="admin-subnav-link <%= locals.activeTab === 'categories' ? 'active' : '' %>">Categories</a>
    <a href="/admin/products"
      class="admin-subnav-link <%= locals.activeTab === 'products' ? 'active' : '' %>">Products</a>
