<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://unpkg.com/lucide@latest"></script>
<script src="/js/auth.js"></script>

<script>
  // Global AJAX Error Handler for Stale Sessions
  $.ajaxSetup({
    error: function(xhr) {
      if (xhr.status === 401) {
        localStorage.removeItem('token');
        if (window.Swal) {
          const Toast = Swal.mixin({
            toast: true, position: 'bottom-end', showConfirmButton: false, timer: 1500, customClass: { popup: 'swal2-toast' }
          });
          Toast.fire({ icon: 'error', title: 'Session expired. Please log in again.' });
        }
        setTimeout(() => {
          window.location.replace('/login');
        }, 500);
      } else if (xhr.status === 0 || xhr.status >= 500) {
        localStorage.removeItem('token');
        if (window.Swal) {
          const Toast = Swal.mixin({
            toast: true, position: 'bottom-end', showConfirmButton: false, timer: 1500, customClass: { popup: 'swal2-toast' }
          });
          Toast.fire({ icon: 'error', title: 'Connection lost. Logging out...' });
        }
        setTimeout(() => {
          window.location.replace('/login');
        }, 500);
      }
    }
  });
</script>
