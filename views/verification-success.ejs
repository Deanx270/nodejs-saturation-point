<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('partials/head') %>
</head>

<body>
  <%- include('partials/header') %>

    <main class="auth-wrapper container">
      <div class="auth-card" style="text-align: center;">
        <div style="display: flex; justify-content: center; margin-bottom: 24px;">
          <i data-lucide="check-circle" style="width: 64px; height: 64px; color: var(--accent-gold);"></i>
        </div>
        <h2 class="brand-font" style="margin-bottom: 16px;">Verification Successful</h2>
        <p style="color: var(--text-muted); margin-bottom: 32px;">
          Your email has been successfully verified. You now have full access to our premium catalog.
        </p>
        <a href="/login" class="btn-submit"
          style="display: inline-block; width: auto; padding: 16px 48px; text-decoration: none;">Proceed to Login</a>
      </div>
    </main>

    <%- include('partials/footer') %>
      <%- include('partials/scripts') %>
        <script>
          lucide.createIcons();
        </script>
</body>

</html>