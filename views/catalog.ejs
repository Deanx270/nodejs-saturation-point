<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('partials/head') %>
    <!-- Force override any overflow that breaks sticky positioning -->
    <style>
      html,
      body,
      .container {
        overflow: visible !important;
        overflow-x: clip !important;
      }
    </style>
</head>

<body>

  <%- include('partials/header') %>

    <!-- Removed padding-top 60px to fix the massive empty gap -->
    <main class="container" style="padding-bottom: 120px;">

      <!-- Tightened the margin below the title so it relates to the search bar -->
      <h2 class="brand-font"
        style="text-align: center; margin-top: 2rem; margin-bottom: 1rem; font-size: 2.5rem; color: var(--text-main);">
        The Complete Catalog</h2>

      <!-- Reduced padding-bottom from 25px to 10px to tighten the gap below -->
      <div class="filter-bar-sticky-container"
        style="position: sticky; top: 85px; z-index: 50; background: transparent; padding: 10px 0 30px 0; pointer-events: none;">
        <div class="filter-bar" style="display: flex; justify-content: center; width: 100%; pointer-events: auto;">
          <div class="search-filter-wrapper"
            style="display: flex; align-items: center; background: #FFFFFF; border-radius: 50px; box-shadow: 0 8px 32px rgba(0,0,0,0.08); border: 1px solid rgba(27,38,59,0.08); padding: 6px 12px; width: 100%; max-width: 650px;">
            <i data-lucide="search" style="color: var(--text-muted); margin-left: 12px; width: 20px;"></i>
            <input type="text" id="searchFilter" placeholder="Search products..."
              style="border: none; outline: none; background: transparent; padding: 12px 15px; width: 100%; font-family: 'Montserrat', sans-serif; font-size: 1rem;">
            <div class="filter-dropdown-container" style="position: relative;">
              <button id="toggleFilterMenu" class="filter-btn"
                style="background: none; border: none; border-left: 1px solid rgba(27,38,59,0.1); padding-left: 18px; padding-right: 10px; cursor: pointer; display: flex; align-items: center; gap: 8px; font-weight: 500; font-family: 'Montserrat', sans-serif;">
                <i data-lucide="sliders-horizontal" style="width: 18px; height: 18px;"></i> Filter
              </button>
              <div id="filterMenu" class="filter-menu">
                <!-- Filter Dropdowns -->
                <div class="filter-menu-group">
                  <label class="form-label" style="font-size: 0.8rem;">Category</label>
                  <select class="filter-select" id="categoryFilter" style="width: 100%;">
                    <option value="">All Categories</option>
                    <option value="Pen">Pens</option>
                    <option value="Ink">Inks</option>
                    <option value="Paper">Paper</option>
                    <option value="Accessory">Accessories</option>
                  </select>
                </div>
                <div class="filter-menu-group">
                  <label class="form-label" style="font-size: 0.8rem;">Brand</label>
                  <select class="filter-select" id="brandFilter" style="width: 100%;">
                    <option value="">All Brands</option>
                  </select>
                </div>
                <div class="filter-menu-group">
                  <label class="form-label" style="font-size: 0.8rem;">Price Range</label>
                  <div class="price-range-inputs">
                    <div class="price-input-wrapper">
                      <span class="currency-symbol">₱</span>
                      <input type="number" id="minPrice" placeholder="Min" min="0">
                    </div>
                    <span style="color: var(--text-muted);">-</span>
                    <div class="price-input-wrapper">
                      <span class="currency-symbol">₱</span>
                      <input type="number" id="maxPrice" placeholder="Max" min="0">
                    </div>
                  </div>
                </div>
                <div class="filter-menu-group" style="margin-bottom: 0;">
                  <label class="form-label" style="font-size: 0.8rem;">Sort By</label>
                  <select class="filter-select" id="sortFilter" style="width: 100%;">
                    <option value="newest">Newest Arrivals</option>
                    <option value="price_asc">Price: Low to High</option>
                    <option value="price_desc">Price: High to Low</option>
                  </select>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Added gap and adjusted grid columns to ensure responsive cards -->
      <div class="bento-grid" id="productGrid"
        style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem; width: 100%; grid-auto-rows: auto;">
        <!-- Products will be injected here via AJAX -->
      </div>
      <div id="catalogSpinner" class="luxury-spinner" style="display: none; margin: 2rem auto;"></div>
    </main>

    <%- include('partials/footer') %>
      <%- include('partials/scripts') %>
        <script src="/js/catalog.js"></script>
</body>

</html>