<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('partials/head') %>
</head>

<body>

  <nav class="navbar-sticky">
    <div class="container navbar-inner">
      <a href="/" class="brand-logo">The Saturation Point</a>
      <div class="nav-links">
        <a href="/catalog" class="nav-link">Catalog</a>
        <a href="/register" class="nav-link">Register</a>
      </div>
    </div>
  </nav>

  <div class="auth-wrapper">
    <div class="auth-card">
      <h2 class="brand-font">Sign In</h2>
      <form id="loginForm" method="POST" onsubmit="event.preventDefault();">
        <div class="form-group">
          <label class="form-label" for="email">Email Address</label>
          <input type="email" id="email" name="email" class="form-control" placeholder="Enter your email" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input type="password" id="password" name="password" class="form-control" placeholder="Enter your password"
            required>
        </div>
        <button type="submit" class="btn-submit">Authenticate</button>
      </form>
      <div class="auth-footer">
        <span>Don't have an account? <a href="/register">Register here</a></span>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

    <%- include('partials/scripts') %>
</body>

</html>