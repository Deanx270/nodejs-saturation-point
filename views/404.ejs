<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main style="min-height: 70vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 40px;">
    <i data-lucide="compass" style="width: 64px; height: 64px; color: var(--accent-gold); margin-bottom: 24px;"></i>
    <h1 class="brand-font" style="font-size: 3rem; margin-bottom: 16px;">Page Not Found</h1>
    <p style="color: var(--text-muted); font-size: 1.1rem; max-width: 500px; margin-bottom: 32px;">The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.</p>
    <a href="/catalog" class="btn-primary" style="text-decoration: none; display: inline-block;">Return to Catalog</a>
  </main>

  <%- include('partials/footer') %>

  <%- include('partials/scripts') %>
  <script>lucide.createIcons();</script>
</body>
</html>
